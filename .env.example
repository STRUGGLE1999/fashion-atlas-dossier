# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"
AI_REQUEST_TIMEOUT_MS="30000"

# DATABASE_URL: Neon Postgres connection string for persisted fashion news and daily AI curations.
# Install Neon from the Vercel Marketplace and copy the provided DATABASE_URL.
DATABASE_URL="postgres://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# CRON_SECRET: Optional. If set, manual calls to the cron endpoint must include
# Authorization: Bearer YOUR_SECRET. Vercel Cron itself can also be configured to pass this.
CRON_SECRET="MY_CRON_SECRET"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
